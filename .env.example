SCRAPINGDOG_ENABLED=false
SCRAPINGDOG_API_KEY=your_scrapingdog_api_key_here
SCRAPINGDOG_BASE_URL=https://api.scrapingdog.com/google
SCRAPINGDOG_COUNTRY=vn
SCRAPINGDOG_DOMAIN=google.com
SCRAPINGDOG_COMBINED_OUTPUT=true
SCRAPINGDOG_TIMEOUT_MS=8000
SCRAPINGDOG_MAX_QUERIES_PER_TRIP=1
SCRAPINGDOG_CACHE_ENABLED=true
SCRAPINGDOG_CACHE_TTL_DAYS=14
SCRAPINGDOG_ONLY_FOR_PREMIUM=false
GOLA_AI_GENERATE_USE_VERIFIED_CANDIDATE_POOL=true
GOLA_AI_GENERATE_CRITIC_ENABLED=true
GOLA_AI_GENERATE_DEEP_GAP_FILLER_ENABLED=true
GOLA_AI_GENERATE_MAX_PROVIDER_CALLS=10
GOLA_AI_GENERATE_MAX_CANDIDATES_TO_VERIFY=12
GOLA_AI_GENERATE_TARGET_VERIFIED_CANDIDATES=10
GOLA_AI_GENERATE_FALLBACK_CATEGORY_SEARCH_ENABLED=true
GOLA_AI_IMPROVE_CRITIC_ENABLED=true
GOLA_AI_IMPROVE_MAX_PROVIDER_CALLS=20
PAYMENT_PROVIDER=VIETQR

# Supabase Storage (replaces Cloudflare R2 for file uploads)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=trip-memory-photos
